<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Youtube Search</title>
     <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        body{
            background-color: #837d7d;
        }
        #main{
            margin-top: 120px;
            margin-left: 50%;
            background: #fff;
            width: 300px;
            height: 150px;
            border: 2px solid white;
            border-radius: 5px;
        }
        .ins{
            padding-left: 10px;
        }
    </style>
</head>
<body>
    <div id="main">
        <div class="ins">
             <h3> <i class="fa-brands fa-youtube"></i> Youtube Search</h3>
             <form action="https://www.youtube.com/results"  method="get" target="_blank">
                <input type="text" placeholder="Search Youtube..." name="search_query" required><br><br>
                <button type="submit">Search</button>
             </form>
        </div>
    </div>
</body>
</html>
